---
import ThemeToggle from "@components/ThemeToggle.astro";
import { withBase } from "@utils/withBase";
import { siteMeta } from "@lib/siteMeta";

const primaryLinks = [
  { href: "/atlas", label: "Atlas" },
  { href: "/papers", label: "Papers" },
  { href: "/topics", label: "Topics" },
  { href: "/applications", label: "Applications" },
  { href: "/observatory", label: "Signals" }
];

const trustLinks = [
  { href: "/trust", label: "Trust" },
  { href: "/trust/editorial", label: "Editorial" },
  { href: "/trust/provenance", label: "Provenance" },
  { href: "/trust/ranking", label: "Ranking" }
];
---
<header class="site-header">
  <div class="container header-shell">
    <a class="brand" href={withBase("/")}>
      <span class="brand-mark">C</span>
      <span class="brand-copy">
        <strong>{siteMeta.title}</strong>
        <small>{siteMeta.tagline}</small>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      {primaryLinks.map((link) => (
        <a href={withBase(link.href)}>{link.label}</a>
      ))}
      <details class="trust-menu">
        <summary>Trust</summary>
        <div class="trust-panel">
          {trustLinks.map((link) => (
            <a href={withBase(link.href)}>{link.label}</a>
          ))}
        </div>
      </details>
    </nav>

    <div class="header-actions">
      <button class="button ghost cmdk-trigger" type="button" data-cmdk-open>
        Search <span class="kbd">Cmd+K</span>
      </button>
      <a class="button secondary" href={withBase("/learn")}>Start here</a>
      <ThemeToggle />
    </div>

    <details class="mobile-menu">
      <summary>Menu</summary>
      <div class="mobile-panel">
        {primaryLinks.map((link) => (
          <a href={withBase(link.href)}>{link.label}</a>
        ))}
        {trustLinks.map((link) => (
          <a href={withBase(link.href)}>{link.label}</a>
        ))}
        <a href={withBase("/learn")}>Start here</a>
        <a href={withBase("/contribute")}>Contribute</a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    backdrop-filter: blur(18px);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
  }

  .header-shell {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.2rem;
    padding: 0.9rem 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
  }

  .brand-mark {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    display: inline-grid;
    place-items: center;
    background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent-2) 72%, white));
    color: white;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    box-shadow: 0 12px 30px -20px var(--shadow);
  }

  .brand-copy {
    display: grid;
    gap: 0.1rem;
  }

  .brand-copy strong {
    font-size: 0.96rem;
    letter-spacing: 0.01em;
  }

  .brand-copy small {
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .primary-nav {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
  }

  .primary-nav a,
  .primary-nav summary {
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    color: var(--muted);
  }

  .primary-nav a:hover,
  .primary-nav summary:hover,
  .trust-menu[open] > summary {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .trust-menu {
    position: relative;
  }

  .trust-menu summary {
    list-style: none;
    cursor: pointer;
  }

  .trust-menu summary::-webkit-details-marker {
    display: none;
  }

  .trust-panel {
    position: absolute;
    top: 2.8rem;
    left: 0;
    min-width: 190px;
    display: grid;
    gap: 0.2rem;
    padding: 0.55rem;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-elevated) 92%, white);
    box-shadow: 0 30px 60px -42px var(--shadow);
  }

  .trust-panel a {
    padding: 0.55rem 0.7rem;
  }

  .header-actions {
    display: none;
    align-items: center;
    gap: 0.7rem;
  }

  .mobile-menu {
    justify-self: end;
  }

  .mobile-menu summary {
    list-style: none;
    cursor: pointer;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-panel {
    position: absolute;
    right: 1.25rem;
    top: 4rem;
    min-width: 220px;
    display: grid;
    gap: 0.3rem;
    padding: 0.7rem;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-elevated) 94%, white);
    box-shadow: 0 30px 60px -42px var(--shadow);
  }

  .mobile-panel a {
    padding: 0.65rem 0.7rem;
    border-radius: 12px;
  }

  .mobile-panel a:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  @media (min-width: 980px) {
    .primary-nav,
    .header-actions {
      display: flex;
    }

    .mobile-menu {
      display: none;
    }
  }
</style>
