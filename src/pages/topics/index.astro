---
import BaseLayout from "@layouts/BaseLayout.astro";
import { readJson } from "@utils/data";
import { withBase } from "@utils/withBase";

const [topics, facets] = await Promise.all([
  readJson("taxonomy/topics.json"),
  readJson("navigator/facets.json")
]);

const groupOrder = [
  "Foundations",
  "Discovery",
  "Inference",
  "Representation",
  "Sequential",
  "LLMs & Agents",
  "Robustness",
  "Fairness & Policy",
  "Systems"
];

const grouped = groupOrder.map((group) => ({
  group,
  topics: topics
    .filter((topic) => topic.group === group)
    .sort((a, b) => (a.priority ?? 3) - (b.priority ?? 3))
}));
---
<BaseLayout wide title="Topics - Causal AI Futures" description="Navigate the causal AI atlas by topic, from foundations to frontier systems.">
  <section class="section hero hero-ambient">
    <div class="container topics-hero">
      <div>
        <p class="eyebrow">Topic Dossiers</p>
        <h1>The causal AI map, grouped by the actual research questions.</h1>
        <p class="subtle hero-copy">
          Every topic page now acts like a dossier: thesis, canonical papers, rising work, live feeds, tools, and open
          questions in one place.
        </p>
      </div>
      <div class="card stats-card">
        <div>
          <span>Topics</span>
          <strong>{topics.length}</strong>
        </div>
        <div>
          <span>Corpus</span>
          <strong>{facets.counts.papers} papers</strong>
        </div>
        <div>
          <span>Groups</span>
          <strong>{groupOrder.length}</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container topic-groups">
      {grouped.map(({ group, topics }) => (
        <section class="topic-group">
          <div class="section-header">
            <p class="eyebrow">{group}</p>
            <h2>{group}</h2>
          </div>
          <div class="topic-grid">
            {topics.map((topic) => (
              <a class="card topic-card" href={withBase(`/topics/${topic.id}`)}>
                <span class="topic-count">{facets.counts.topics?.[topic.id] ?? 0} papers</span>
                <h3>{topic.title}</h3>
                <p class="subtle">{topic.scope}</p>
                <div class="tag-row">
                  {topic.anchors.slice(0, 2).map((anchor) => (
                    <span class="chip">{anchor}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <style>
    h1 {
      margin: 0;
      font-size: clamp(2.8rem, 4.4vw, 4.6rem);
      line-height: 1.02;
      max-width: 12ch;
    }

    .topics-hero {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
      align-items: end;
      position: relative;
      z-index: 1;
    }

    .hero-copy {
      max-width: 58ch;
      line-height: 1.7;
    }

    .stats-card {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .stats-card span,
    .topic-count {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.72rem;
    }

    .stats-card strong {
      display: block;
      font-size: 1.5rem;
      margin-top: 0.35rem;
    }

    .topic-groups {
      display: grid;
      gap: 2.5rem;
    }

    .topic-grid {
      display: grid;
      gap: 1.2rem;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }

    .topic-card {
      display: grid;
      gap: 0.8rem;
      min-height: 100%;
    }

    .topic-card h3 {
      margin: 0;
      font-size: 1.35rem;
    }

    @media (max-width: 980px) {
      .topics-hero,
      .stats-card {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
