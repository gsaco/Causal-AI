---
import BaseLayout from "@layouts/BaseLayout.astro";
import { readJson } from "@utils/data";
import { withBase } from "@utils/withBase";

const [topics, catalog, facets, lenses, pages] = await Promise.all([
  readJson("taxonomy/topics.json"),
  readJson("navigator/catalog.json"),
  readJson("navigator/facets.json"),
  readJson("navigator/lenses.json"),
  readJson("navigator/pages.json")
]);

const topicLabels = Object.fromEntries(topics.map((topic) => [topic.id, topic.title]));
const initialLens = "rising";
const initialIds = pages.lenses[initialLens]?.["1"] ?? [];
const catalogMap = new Map(catalog.map((item) => [item.arxiv_id, item]));
const initialItems = initialIds.map((id) => catalogMap.get(id)).filter(Boolean);
const catalogUrl = withBase("/data/navigator/catalog.json");
const lensesUrl = withBase("/data/navigator/lenses.json");
const paperBase = withBase("/papers/");
---
<BaseLayout wide title="Paper Navigator - Causal AI Futures" description="Faceted navigation across a live arXiv-first causal AI corpus.">
  <section class="section hero hero-ambient">
    <div class="container explorer-hero">
      <div>
        <p class="eyebrow">Paper Navigator</p>
        <h1>Navigate causal AI like a research atlas, not a flat list.</h1>
        <p class="subtle hero-copy">
          Start with the rising lens, switch to canonical landmarks, or slice the corpus by topic, application,
          category, year, and cross-list behavior.
        </p>
      </div>
      <div class="hero-stats card">
        <div>
          <span>Papers</span>
          <strong>{facets.counts.papers}</strong>
        </div>
        <div>
          <span>Topics</span>
          <strong>{Object.keys(facets.counts.topics).length}</strong>
        </div>
        <div>
          <span>Groups</span>
          <strong>{Object.keys(facets.counts.groups).length}</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container explorer-layout">
      <aside class="card filter-panel">
        <div class="filter-block">
          <label for="paper-search">Search</label>
          <input id="paper-search" type="search" placeholder="Title, abstract preview, or author" />
        </div>

        <div class="filter-block">
          <label for="lens-select">Lens</label>
          <div class="lens-row">
            <button type="button" class="chip active" data-lens="rising">Rising</button>
            <button type="button" class="chip secondary" data-lens="canonical">Canonical</button>
            <button type="button" class="chip secondary" data-lens="latest">Latest</button>
          </div>
        </div>

        <div class="filter-block">
          <label for="topic-filter">Topic</label>
          <select id="topic-filter">
            <option value="">All topics</option>
            {topics.map((topic) => (
              <option value={topic.id}>{topic.title}</option>
            ))}
          </select>
        </div>

        <div class="filter-block">
          <label for="group-filter">Group</label>
          <select id="group-filter">
            <option value="">All groups</option>
            {Object.keys(facets.counts.groups).sort().map((group) => (
              <option value={group}>{group}</option>
            ))}
          </select>
        </div>

        <div class="filter-block">
          <label for="application-filter">Application</label>
          <select id="application-filter">
            <option value="">All applications</option>
            {Object.keys(facets.counts.applications).sort().map((app) => (
              <option value={app}>{app.replace(/-/g, " ")}</option>
            ))}
          </select>
        </div>

        <div class="filter-block">
          <label for="year-filter">Year</label>
          <select id="year-filter">
            <option value="">All years</option>
            {Object.keys(facets.counts.years).sort((a, b) => Number(b) - Number(a)).map((year) => (
              <option value={year}>{year}</option>
            ))}
          </select>
        </div>

        <div class="filter-block">
          <label for="category-filter">Category</label>
          <select id="category-filter">
            <option value="">All categories</option>
            {Object.keys(facets.counts.categories).sort().map((category) => (
              <option value={category}>{category}</option>
            ))}
          </select>
        </div>

        <div class="filter-block check-grid">
          <label><input type="checkbox" id="crosslist" /> Cross-listed only</label>
          <label><input type="checkbox" id="multi-version" /> Version count >= 2</label>
        </div>
      </aside>

      <div class="results-shell">
        <div class="results-toolbar card">
          <div>
            <p class="eyebrow">Results</p>
            <strong id="result-count">{facets.counts.papers} papers</strong>
            <p class="subtle" id="result-label">Showing page 1 from the rising lens.</p>
          </div>
          <div class="toolbar-actions">
            <button class="button secondary" data-export="csv">Export CSV</button>
            <button class="button" data-export="bib">Export BibTeX</button>
          </div>
        </div>

        <div class="paper-list" data-list>
          {initialItems.map((paper) => (
            <article class="card paper-row">
              <div class="row-top">
                <div>
                  <h3><a href={withBase(`/papers/${paper.arxiv_id}`)}>{paper.title}</a></h3>
                  <p class="subtle">{paper.authors.slice(0, 4).join(", ")}</p>
                </div>
                <div class="tag-row compact">
                  {Number(paper.metrics?.canonical_score ?? 0) >= 0.82 && <span class="chip">Canonical</span>}
                  {Number(paper.metrics?.rising_score ?? 0) >= 0.42 && <span class="chip secondary">Rising</span>}
                </div>
              </div>
              <p class="abstract">{paper.abstract_preview}</p>
              <div class="meta-row">
                <span class="chip">arXiv {paper.arxiv_id}</span>
                <span class="chip secondary">Submitted {paper.submitted_at}</span>
                <span class="chip secondary">Updated {paper.updated_at}</span>
                <span class="chip">v{paper.metrics.version_count}</span>
              </div>
              <div class="tag-row compact">
                {paper.topic_ids.slice(0, 4).map((topicId) => (
                  <span class="chip secondary">{topicLabels[topicId] ?? topicId}</span>
                ))}
                {paper.application_tags.slice(0, 2).map((tag) => (
                  <span class="chip secondary">{tag.replace(/-/g, " ")}</span>
                ))}
              </div>
            </article>
          ))}
        </div>

        <div class="pager">
          <button class="button secondary" data-page="prev">Prev</button>
          <span class="subtle" data-page-status>Page 1</span>
          <button class="button secondary" data-page="next">Next</button>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const catalogUrl = "${catalogUrl}";
    const lensesUrl = "${lensesUrl}";
    const paperBase = "${paperBase}";
    const topicLabels = ${JSON.stringify(topicLabels)};
    const initialLens = "${initialLens}";
    const initialCount = ${facets.counts.papers};

    const searchInput = document.getElementById("paper-search");
    const topicFilter = document.getElementById("topic-filter");
    const groupFilter = document.getElementById("group-filter");
    const appFilter = document.getElementById("application-filter");
    const yearFilter = document.getElementById("year-filter");
    const categoryFilter = document.getElementById("category-filter");
    const crosslistOnly = document.getElementById("crosslist");
    const multiVersion = document.getElementById("multi-version");
    const lensButtons = Array.from(document.querySelectorAll("[data-lens]"));
    const list = document.querySelector("[data-list]");
    const resultCount = document.getElementById("result-count");
    const resultLabel = document.getElementById("result-label");
    const pageStatus = document.querySelector("[data-page-status]");
    const pagerButtons = Array.from(document.querySelectorAll("[data-page]"));
    const exportButtons = Array.from(document.querySelectorAll("[data-export]"));
    const pageSize = 24;

    let catalog = null;
    let lenses = null;
    let filteredIds = [];
    let currentPage = 1;
    let activeLens = initialLens;

    async function ensureDataLoaded() {
      if (catalog && lenses) return;
      const [catalogResponse, lensesResponse] = await Promise.all([fetch(catalogUrl), fetch(lensesUrl)]);
      catalog = await catalogResponse.json();
      lenses = await lensesResponse.json();
    }

    function getLensIds() {
      return (lenses?.lenses?.[activeLens] ?? []).slice();
    }

    function cardMatches(card, query) {
      if (!query) return true;
      const haystack = [card.title, card.abstract_preview, ...(card.authors || [])].join(" ").toLowerCase();
      return haystack.includes(query);
    }

    function applyFilters() {
      if (!catalog || !lenses) return;
      const query = (searchInput.value || "").trim().toLowerCase();
      const topicId = topicFilter.value;
      const group = groupFilter.value;
      const app = appFilter.value;
      const year = yearFilter.value;
      const category = categoryFilter.value;
      const orderedIds = getLensIds();
      const orderedMap = new Map(catalog.map((item) => [item.arxiv_id, item]));

      filteredIds = orderedIds.filter((id) => {
        const card = orderedMap.get(id);
        if (!card) return false;
        if (!cardMatches(card, query)) return false;
        if (topicId && !card.topic_ids.includes(topicId)) return false;
        if (group && !card.groups.includes(group)) return false;
        if (app && !card.application_tags.includes(app)) return false;
        if (year && !String(card.submitted_at).startsWith(year)) return false;
        if (category && !card.categories.includes(category)) return false;
        if (crosslistOnly.checked && Number(card.metrics?.cross_list_count || 0) === 0) return false;
        if (multiVersion.checked && Number(card.metrics?.version_count || 0) < 2) return false;
        return true;
      });

      currentPage = 1;
      renderPage();
    }

    function renderPage() {
      if (!catalog || !lenses) return;
      const orderedMap = new Map(catalog.map((item) => [item.arxiv_id, item]));
      const maxPage = Math.max(1, Math.ceil(filteredIds.length / pageSize));
      currentPage = Math.min(currentPage, maxPage);
      const start = (currentPage - 1) * pageSize;
      const pageItems = filteredIds.slice(start, start + pageSize).map((id) => orderedMap.get(id)).filter(Boolean);
      list.replaceChildren(...pageItems.map(renderCard));
      resultCount.textContent = `${filteredIds.length} papers`;
      resultLabel.textContent = `Lens: ${activeLens}. Filters update client-side after the compact catalog loads.`;
      pageStatus.textContent = `Page ${currentPage} of ${maxPage}`;
    }

    function renderCard(card) {
      const article = document.createElement("article");
      article.className = "card paper-row";
      article.dataset.id = card.arxiv_id;
      article.innerHTML = `
        <div class="row-top">
          <div>
            <h3><a href="${paperBase}${card.arxiv_id}">${card.title}</a></h3>
            <p class="subtle">${(card.authors || []).slice(0, 4).join(", ")}</p>
          </div>
          <div class="tag-row compact">
            ${Number(card.metrics?.canonical_score || 0) >= 0.82 ? '<span class="chip">Canonical</span>' : ""}
            ${Number(card.metrics?.rising_score || 0) >= 0.42 ? '<span class="chip secondary">Rising</span>' : ""}
          </div>
        </div>
        <p class="abstract">${card.abstract_preview}</p>
        <div class="meta-row">
          <span class="chip">arXiv ${card.arxiv_id}</span>
          <span class="chip secondary">Submitted ${card.submitted_at}</span>
          <span class="chip secondary">Updated ${card.updated_at}</span>
          <span class="chip">v${card.metrics.version_count}</span>
        </div>
        <div class="tag-row compact">
          ${(card.topic_ids || []).slice(0, 4).map((topicId) => `<span class="chip secondary">${topicLabels[topicId] || topicId}</span>`).join("")}
          ${(card.application_tags || []).slice(0, 2).map((tag) => `<span class="chip secondary">${tag.replace(/-/g, " ")}</span>`).join("")}
        </div>
      `;
      return article;
    }

    async function handleInteraction() {
      await ensureDataLoaded();
      applyFilters();
    }

    lensButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        activeLens = button.dataset.lens;
        lensButtons.forEach((item) => item.classList.remove("active"));
        lensButtons.forEach((item) => item.classList.add("secondary"));
        button.classList.add("active");
        button.classList.remove("secondary");
        await handleInteraction();
      });
    });

    [searchInput, topicFilter, groupFilter, appFilter, yearFilter, categoryFilter, crosslistOnly, multiVersion].forEach((el) => {
      el.addEventListener("input", handleInteraction);
      el.addEventListener("change", handleInteraction);
    });

    pagerButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        await ensureDataLoaded();
        const maxPage = Math.max(1, Math.ceil(filteredIds.length / pageSize));
        if (button.dataset.page === "prev") currentPage = Math.max(1, currentPage - 1);
        if (button.dataset.page === "next") currentPage = Math.min(maxPage, currentPage + 1);
        renderPage();
      });
    });

    exportButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        await ensureDataLoaded();
        const orderedMap = new Map(catalog.map((item) => [item.arxiv_id, item]));
        const selected = filteredIds.slice(0, 200).map((id) => orderedMap.get(id)).filter(Boolean);
        const type = button.dataset.export;
        if (type === "csv") {
          const rows = ["arxiv_id,title,submitted_at,topics,applications"];
          selected.forEach((item) => {
            const title = item.title.replace(/\"/g, "\"\"");
            rows.push(
              `${item.arxiv_id},\"${title}\",${item.submitted_at},\"${(item.topic_ids || []).join("|")}\",\"${(item.application_tags || []).join("|")}"`
            );
          });
          download("causal-ai-navigator.csv", rows.join("\n"));
          return;
        }
        const bib = selected
          .map((item) => `@article{arxiv:${item.arxiv_id},\n  title={${item.title}},\n  eprint={${item.arxiv_id}},\n  archivePrefix={arXiv}\n}`)
          .join("\n\n");
        download("causal-ai-navigator.bib", bib);
      });
    });

    function download(filename, content) {
      const blob = new Blob([content], { type: "text/plain" });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download = filename;
      link.click();
      URL.revokeObjectURL(link.href);
    }

    filteredIds = ${JSON.stringify(initialIds)};
    pageStatus.textContent = "Page 1";
  </script>

  <style>
    h1 {
      font-size: clamp(2.5rem, 4vw, 4.2rem);
      line-height: 1.02;
      margin: 0;
      max-width: 12ch;
    }

    .hero-copy {
      max-width: 62ch;
      font-size: 1.02rem;
      line-height: 1.7;
    }

    .explorer-hero {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
      align-items: end;
      position: relative;
      z-index: 1;
    }

    .hero-stats {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hero-stats span {
      display: block;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 0.35rem;
    }

    .hero-stats strong {
      font-size: 1.6rem;
    }

    .explorer-layout {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: 300px minmax(0, 1fr);
      align-items: start;
    }

    .filter-panel {
      position: sticky;
      top: 5.5rem;
      display: grid;
      gap: 1rem;
    }

    .filter-block {
      display: grid;
      gap: 0.55rem;
    }

    .filter-block label {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .filter-panel input,
    .filter-panel select {
      padding: 0.8rem 0.95rem;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--bg-elevated) 92%, white);
    }

    .lens-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .check-grid {
      font-size: 0.95rem;
    }

    .results-shell {
      display: grid;
      gap: 1.25rem;
    }

    .results-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .toolbar-actions {
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
    }

    .paper-list {
      display: grid;
      gap: 1rem;
    }

    .paper-row {
      display: grid;
      gap: 0.9rem;
    }

    .row-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .row-top h3 {
      margin: 0 0 0.4rem;
      font-size: 1.35rem;
    }

    .abstract {
      margin: 0;
      color: var(--muted);
      font-family: var(--font-serif);
      line-height: 1.6;
    }

    .meta-row,
    .compact {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
    }

    .pager {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    @media (max-width: 980px) {
      .explorer-hero,
      .explorer-layout,
      .hero-stats,
      .results-toolbar {
        grid-template-columns: 1fr;
        display: grid;
      }

      .filter-panel {
        position: static;
      }

      .row-top,
      .pager {
        display: grid;
      }
    }
  </style>
</BaseLayout>
