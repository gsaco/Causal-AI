---
import BaseLayout from "@layouts/BaseLayout.astro";
import PaperCard from "@components/PaperCard.astro";
import ProvenancePanel from "@components/ProvenancePanel.astro";
import HeroCausalGraph from "@components/viz/HeroCausalGraph.astro";
import CoverageBadge from "@components/CoverageBadge.astro";
import { readJson } from "@utils/data";
import { withBase } from "@utils/withBase";
import { getCollection } from "astro:content";

const [papers, build, coverage, topics, digests, applications, featured, facets] = await Promise.all([
  readJson("papers.index.json"),
  readJson("provenance/build.json"),
  readJson("metrics/citation_coverage.json"),
  readJson("taxonomy/topics.json"),
  getCollection("digests"),
  getCollection("applications"),
  readJson("navigator/featured.json"),
  readJson("navigator/facets.json")
]);

const paperMap = new Map(papers.map((paper) => [paper.arxiv_id, paper]));
const canonicalHighlights = featured.featured.canonical.map((id) => paperMap.get(id)).filter(Boolean).slice(0, 3);
const risingHighlights = featured.featured.rising.map((id) => paperMap.get(id)).filter(Boolean).slice(0, 3);
const mixedHighlights = featured.featured.mixed.map((id) => paperMap.get(id)).filter(Boolean).slice(0, 4);
const latestDigest = [...digests].sort((a, b) => (a.data.week < b.data.week ? 1 : -1))[0];
const featuredTopics = topics.filter((topic) => (topic.priority ?? 3) <= 2).slice(0, 6);
const featuredApplications = applications.slice(0, 4);
---
<BaseLayout wide title="Causal AI Futures" description="Causal AI Futures is a premium atlas for causal AI: editorial guidance, arXiv navigation, and transparent provenance in one place.">
  <section class="section hero hero-ambient atlas-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Research Atlas</p>
        <h1>The field guide for causal AI, built around real papers instead of slogans.</h1>
        <p class="hero-text">
          Navigate structural causality, discovery, counterfactual evaluation, causal agents, and intervention-aware systems
          through a living arXiv-first atlas that blends canonical landmarks with the newest rising work.
        </p>
        <div class="hero-actions">
          <a class="button" href={withBase("/papers")}>Open Paper Navigator</a>
          <a class="button secondary" href={withBase("/topics")}>Browse Topic Dossiers</a>
        </div>
        <div class="hero-strip">
          <div>
            <span>Corpus</span>
            <strong>{facets.counts.papers} papers</strong>
          </div>
          <div>
            <span>Topics</span>
            <strong>{Object.keys(facets.counts.topics).length}</strong>
          </div>
          <div>
            <span>Coverage</span>
            <CoverageBadge value={Math.round((coverage.overall.coverage ?? 0) * 100)} />
          </div>
        </div>
      </div>

      <div class="hero-side">
        <div class="hero-canvas card">
          <HeroCausalGraph />
        </div>
        <div class="hero-provenance card">
          <div class="hero-provenance-head">
            <div>
              <p class="eyebrow">Snapshot</p>
              <h3>{build.snapshot}</h3>
            </div>
            <span class="chip">Harvest {build.harvest_window}</span>
          </div>
          <ProvenancePanel provenance={build} />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-band">
    <div class="container state-band">
      <div>
        <p class="eyebrow">Field State</p>
        <h2>Canonical ideas are solidifying while new evaluation and agentic work accelerates.</h2>
      </div>
      <div class="state-cards">
        <div class="card">
          <span>Canonical lens</span>
          <strong>Landmarks stay visible</strong>
          <p class="subtle">Classic papers are pinned alongside fresh work so the site stays useful to both newcomers and researchers.</p>
        </div>
        <div class="card">
          <span>Rising lens</span>
          <strong>Momentum is explicit</strong>
          <p class="subtle">Recent submissions, topic momentum, cross-listing, and revision churn surface what is actually moving now.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-section">
      <div class="section-header">
        <p class="eyebrow">Featured Mix</p>
        <h2>Canonical + rising papers, together</h2>
        <p>The homepage defaults to a blended lens so users get both the foundations and the frontier.</p>
      </div>
      <div class="mixed-grid">
        {mixedHighlights.map((paper) => (
          <PaperCard paper={paper} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container editorial-grid">
      <div>
        <div class="section-header">
          <p class="eyebrow">Canonical Papers</p>
          <h2>Landmarks that still organize the field</h2>
        </div>
        <div class="stack">
          {canonicalHighlights.map((paper) => (
            <PaperCard paper={paper} />
          ))}
        </div>
      </div>
      <div>
        <div class="section-header">
          <p class="eyebrow">Rising Papers</p>
          <h2>New work worth reading now</h2>
        </div>
        <div class="stack">
          {risingHighlights.map((paper) => (
            <PaperCard paper={paper} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container topic-spotlights">
      <div class="section-header">
        <p class="eyebrow">Topic Dossiers</p>
        <h2>The causal AI map, organized by questions that matter</h2>
        <p>Each topic page combines editorial framing, canonical papers, rising work, tools, benchmarks, and a live arXiv feed.</p>
      </div>
      <div class="card-grid">
        {featuredTopics.map((topic) => (
          <a class="card spotlight-card" href={withBase(`/topics/${topic.id}`)}>
            <span class="spotlight-group">{topic.group}</span>
            <h3>{topic.title}</h3>
            <p class="subtle">{topic.scope}</p>
            <div class="tag-row">
              {topic.anchors.slice(0, 2).map((anchor) => (
                <span class="chip">{anchor}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container application-grid">
      <div class="section-header">
        <p class="eyebrow">Applications</p>
        <h2>Where intervention-aware modeling becomes operational</h2>
      </div>
      <div class="card-grid">
        {featuredApplications.map((app) => (
          <a class="card" href={withBase(`/applications/${app.slug}`)}>
            <h3>{app.data.title}</h3>
            <p class="subtle">{app.data.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {latestDigest && (
    <section class="section">
      <div class="container digest-band card">
        <div>
          <p class="eyebrow">Weekly Digest</p>
          <h2>{latestDigest.data.title}</h2>
          <p class="subtle">{latestDigest.data.summary}</p>
        </div>
        <a class="button" href={withBase(`/digest/weekly/${latestDigest.data.week}`)}>Read digest</a>
      </div>
    </section>
  )}

  <style>
    h1 {
      font-size: clamp(3rem, 5.4vw, 5.2rem);
      line-height: 0.98;
      margin: 0;
      max-width: 11ch;
    }

    h2 {
      margin: 0;
    }

    .atlas-hero {
      padding-top: var(--space-9);
    }

    .hero-grid {
      display: grid;
      gap: 2rem;
      grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.95fr);
      align-items: start;
      position: relative;
      z-index: 1;
    }

    .hero-copy,
    .hero-side {
      display: grid;
      gap: 1.2rem;
    }

    .hero-text {
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.7;
      max-width: 58ch;
    }

    .hero-actions {
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
    }

    .hero-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
      margin-top: 0.5rem;
    }

    .hero-strip div {
      padding: 1rem;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--bg-elevated) 84%, white);
      display: grid;
      gap: 0.3rem;
    }

    .hero-strip span {
      color: var(--muted);
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
    }

    .hero-canvas {
      min-height: 280px;
      display: grid;
      place-items: center;
    }

    .hero-provenance-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.8rem;
    }

    .hero-provenance-head h3 {
      font-size: 2rem;
      margin: 0;
    }

    .state-band {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
      align-items: start;
    }

    .state-cards {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .state-cards span,
    .spotlight-group {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.72rem;
    }

    .state-cards strong {
      font-size: 1.2rem;
    }

    .mixed-grid {
      display: grid;
      gap: 1.4rem;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }

    .editorial-grid {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .stack {
      display: grid;
      gap: 1.25rem;
    }

    .spotlight-card {
      min-height: 100%;
    }

    .digest-band {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    @media (max-width: 980px) {
      .hero-grid,
      .state-band,
      .editorial-grid {
        grid-template-columns: 1fr;
      }

      .hero-strip,
      .state-cards {
        grid-template-columns: 1fr;
      }

      .digest-band {
        display: grid;
      }
    }
  </style>
</BaseLayout>
