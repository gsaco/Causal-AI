---
import BaseLayout from "@layouts/BaseLayout.astro";
import { siteMeta } from "@lib/siteMeta";
import { readJson } from "@utils/data";
import { withBase } from "@utils/withBase";

const [build, coverage, facets] = await Promise.all([
  readJson("provenance/build.json"),
  readJson("metrics/citation_coverage.json"),
  readJson("navigator/facets.json")
]);

const coveragePct = Math.round((coverage.overall.coverage ?? 0) * 100);
---
<BaseLayout title={`About - ${siteMeta.title}`} description="Why Causal AI Futures exists and how it stays evidence-first.">
  <section class="section hero hero-ambient">
    <div class="container about-hero">
      <div>
        <p class="eyebrow">About</p>
        <h1>Built for people who want causal AI explained with sources, not vibes.</h1>
        <p class="subtitle">
          Causal AI Futures is a research atlas for the intervention era. It is designed for readers who want a clean
          map of the field, transparent evidence, and enough context to tell canonical work from fast-moving noise.
        </p>
      </div>

      <div class="card about-stats">
        <div>
          <span>Snapshot</span>
          <strong>{build.snapshot}</strong>
        </div>
        <div>
          <span>Corpus</span>
          <strong>{facets.counts.papers} papers</strong>
        </div>
        <div>
          <span>Coverage</span>
          <strong>{coveragePct}% cited</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container values-grid">
      <article class="card manifesto-card">
        <p class="eyebrow">Editorial stance</p>
        <h2>The site optimizes for legibility, not maximal volume.</h2>
        <p>
          The goal is to make causal AI navigable without pretending the field is settled. We surface assumptions,
          disagreements, and open questions alongside the papers so readers can see where the field is strong and where
          it is still unstable.
        </p>
      </article>

      <article class="card principle-card">
        <h2>Evidence first</h2>
        <p>Claims are anchored to arXiv IDs, with provenance and coverage exposed rather than hidden in the build.</p>
      </article>

      <article class="card principle-card">
        <h2>Canonical plus rising</h2>
        <p>Landmarks stay visible while the navigator highlights recent momentum instead of flattening everything into one feed.</p>
      </article>

      <article class="card principle-card">
        <h2>Static and inspectable</h2>
        <p>The site is built for static hosting, so the data products that power ranking and faceting remain easy to inspect.</p>
      </article>
    </div>
  </section>

  <section class="section section-band">
    <div class="container system-grid">
      <div class="section-header">
        <p class="eyebrow">About</p>
        <h2>How the evidence pipeline works</h2>
        <p>The system is opinionated by design: broad arXiv ingestion first, then relevance gates, rankings, and editorial framing.</p>
      </div>

      <div class="pipeline">
        <article class="card pipeline-step">
          <span>01</span>
          <h3>Harvest</h3>
          <p>Query packs sweep the field through arXiv-first retrieval instead of a single topic query per page.</p>
        </article>
        <article class="card pipeline-step">
          <span>02</span>
          <h3>Filter</h3>
          <p>Off-topic papers are removed before persistence, and application feeds are built separately instead of mirroring the global corpus.</p>
        </article>
        <article class="card pipeline-step">
          <span>03</span>
          <h3>Rank</h3>
          <p>Canonical, rising, and recent scores give the navigator multiple lenses instead of a default recency sort.</p>
        </article>
        <article class="card pipeline-step">
          <span>04</span>
          <h3>Explain</h3>
          <p>Topic dossiers, trend pages, and application briefs translate the corpus into a field guide that can actually be read.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container about-grid">
      <div class="card">
        <h2>Mission</h2>
        <p>
          The goal is to make causal AI navigable without flattening the nuance. We surface signals, disagreements,
          and open problems alongside the papers, so readers can see where the field is converging and where it is not.
        </p>
      </div>
      <div class="card">
        <h2>How evidence works</h2>
        <p>
          Claims are written in a <code>&lt;Claim&gt;</code> block with arXiv IDs. CI checks that evidence exists and
          validates citation coverage. Tendencies must include foundational anchors, new-wave signals, and debates.
        </p>
        <a class="button secondary" href={withBase("/trust/citation-coverage")}>Review coverage</a>
      </div>
      <div class="card">
        <h2>How updates work</h2>
        <p>
          Weekday refreshes ingest new arXiv snapshots. A weekly digest summarizes movement, and provenance logs record
          harvest windows, query packs, and update history.
        </p>
        <a class="button secondary" href={withBase("/trust/update-log")}>See update log</a>
      </div>
      <div class="card">
        <h2>About the author</h2>
        <p>
          {siteMeta.author} builds tools for evidence-first research navigation, with interests in causal inference,
          representation learning, and evaluation.
        </p>
        <a class="button secondary" href={siteMeta.repoUrl} target="_blank" rel="noreferrer">Project repo</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container disclaimer">
      <h2>Disclaimer</h2>
      <p>
        This site is not affiliated with arXiv. arXiv remains the primary source, and every claim should be checked
        against the original papers.
      </p>
    </div>
  </section>

  <style>
    h1 {
      margin: 0 0 0.8rem;
      font-size: clamp(2.8rem, 4.5vw, 4.6rem);
      line-height: 0.98;
      max-width: 11ch;
    }

    .subtitle {
      color: var(--muted);
      max-width: 60ch;
      line-height: 1.75;
      font-size: 1.05rem;
    }

    .about-hero {
      display: grid;
      gap: 1.6rem;
      grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
      align-items: end;
      position: relative;
      z-index: 1;
    }

    .about-stats {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .about-stats span,
    .pipeline-step span {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.72rem;
    }

    .about-stats strong {
      display: block;
      margin-top: 0.35rem;
      font-size: 1.45rem;
    }

    .values-grid {
      display: grid;
      gap: 1.2rem;
      grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
    }

    .manifesto-card,
    .principle-card {
      min-height: 100%;
    }

    .manifesto-card h2,
    .principle-card h2,
    .pipeline-step h3 {
      margin: 0 0 0.6rem;
    }

    .system-grid {
      display: grid;
      gap: 1.5rem;
    }

    .pipeline {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .pipeline-step {
      display: grid;
      gap: 0.45rem;
    }

    .about-grid {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }

    .disclaimer {
      border-radius: var(--radius-4);
      border: 1px dashed var(--border);
      padding: var(--space-5);
      background: color-mix(in srgb, var(--bg-elevated) 85%, transparent);
    }

    @media (max-width: 1100px) {
      .values-grid {
        grid-template-columns: 1fr 1fr;
      }

      .manifesto-card {
        grid-column: 1 / -1;
      }

      .pipeline {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 900px) {
      .about-hero,
      .about-stats,
      .values-grid,
      .pipeline {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
